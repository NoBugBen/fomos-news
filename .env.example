APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=3000
DATABASE_URL=sqlite://data/fomos-news.db
SESSION_COOKIE_NAME=fomos_news_session
# Set this to app_session_id before wiring frontend auth/session flows in the extracted app.
SESSION_SECRET=change-me
INGEST_BEARER_TOKEN=change-me
OAUTH_PORTAL_URL=
# Local dev keeps Vite on :5173 and Rust on :3000. In same-origin deployment, set this to the public app origin.
FRONTEND_BASE_URL=http://localhost:5173
# Optional: when this directory contains the built SPA, the Rust server will serve it on non-/api routes.
FRONTEND_DIST_DIR=extracted/repo/fomos-news/dist/public
